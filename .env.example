# Copy to .env and fill in. Never commit .env.
# Real values in prod live in AWS Secrets Manager.

# ---- FastAPI backend ----
# Shared secret required on every API request (X-API-Key header).
API_KEY=replace-me-local-dev-key

# Postgres connection string. Default matches the db service in docker-compose.yml.
# The `+psycopg` driver selects psycopg3 (matches the pinned dep in api/pyproject.toml).
DATABASE_URL=postgresql+psycopg://carrier:carrier@db:5432/carrier_sales

# FMCSA QCMobile API key. Request at https://mobile.fmcsa.dot.gov/developer
FMCSA_WEBKEY=

# ---- Streamlit dashboard ----
# Where the dashboard calls the backend from inside the docker network.
API_BASE_URL=http://api:8000
# Must match API_KEY above — dashboard presents this to the backend.
DASHBOARD_API_KEY=replace-me-local-dev-key

# ---- AWS (deploy only, not needed for local dev) ----
AWS_REGION=us-east-1
